<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout do widget de calendário para a tela inicial do Android.
  Copie este arquivo para:
  android/app/src/main/res/layout/widget_calendar.xml
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Cabeçalho: data de hoje -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:marginBottom="8dp">

        <TextView
            android:id="@+id/widget_day_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="#534AB7"
            android:textStyle="bold"
            android:text="10"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/widget_weekday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#534AB7"
                android:textStyle="bold"
                android:text="SEXTA-FEIRA"/>

            <TextView
                android:id="@+id/widget_month_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#888780"
                android:text="Abril 2026"/>
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_calendar"
            android:contentDescription="Calendário"/>
    </LinearLayout>

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#e4e2dc"
        android:marginBottom="8dp"/>

    <!-- Lista de eventos (até 4) -->
    <TextView
        android:id="@+id/widget_no_events"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhum evento hoje"
        android:textSize="12sp"
        android:textColor="#888780"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/widget_event_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="5dp"
        android:visibility="gone">
        <View android:id="@+id/widget_dot_1"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/circle_dot" android:layout_marginEnd="7dp"/>
        <TextView android:id="@+id/widget_title_1"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="12sp" android:textColor="#1a1a18"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/widget_time_1"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#888780"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/widget_event_2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <View android:id="@+id/widget_dot_2"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/circle_dot" android:layout_marginEnd="7dp"/>
        <TextView android:id="@+id/widget_title_2"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="12sp" android:textColor="#1a1a18"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/widget_time_2"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#888780"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/widget_event_3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="5dp" android:visibility="gone">
        <View android:id="@+id/widget_dot_3"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/circle_dot" android:layout_marginEnd="7dp"/>
        <TextView android:id="@+id/widget_title_3"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="12sp" android:textColor="#1a1a18"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/widget_time_3"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#888780"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/widget_event_4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone">
        <View android:id="@+id/widget_dot_4"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/circle_dot" android:layout_marginEnd="7dp"/>
        <TextView android:id="@+id/widget_title_4"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="12sp" android:textColor="#1a1a18"
            android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/widget_time_4"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#888780"/>
    </LinearLayout>

</LinearLayout>
